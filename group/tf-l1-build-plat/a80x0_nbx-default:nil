source "$ci_root/marvell_utils.sh"

test_setup() {
	# Parallel builds are broken for this config; so choose serial.
	echo "Choosing serial build."
	set_hook_var "make_j" "1"
}

pre_tf_build() {
	targets="all mrvl_flash" set_tf_build_targets

	fetch_mv_ddr_files
}

post_tf_build() {
	# Run ramoopsies and build verification checks (non-fatal)
	local verify_script="$tf_root/plat/marvell/armada/a8k/a80x0_nbx/verify_build.sh"

	if [ -x "$verify_script" ]; then
		echo "Running a80x0_nbx build verification..."
		CROSS_COMPILE="aarch64-none-elf-" \
			"$verify_script" "$tf_build_root" || \
			echo "WARNING: verify_build.sh reported failures (non-fatal)"
	else
		echo "WARNING: verify_build.sh not found or not executable"
	fi
}
