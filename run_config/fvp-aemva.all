generate_lava_job() {
	local model="base-aemva"

	uart="0" file="tftf.exp" track_expect
	uart="1" file="hold_uart.exp" track_expect

	model="$model" \
		all_optional_cpu_features="1" \
		gen_model_params

	model="$model" gen_fvp_yaml
}
