post_tf_build() {
	# Fetch EDK2 and pre-built partition files
	url="$DOWNLOAD_SERVER_TF_A_URL/spm/FVP_AARCH64_EFI.fd" fetch_file
	url="$DOWNLOAD_SERVER_TF_A_URL/spm/STANDALONESMM.fd" fetch_file

	archive_file "FVP_AARCH64_EFI.fd"
	archive_file "STANDALONESMM.fd"

	build_fip BL33="$archive/FVP_AARCH64_EFI.fd" BL32="$archive/STANDALONESMM.fd"
}

generate_lava_job_template() {
	# The older UART2 and EFI-app flow no longer matches today's shared assets.
	uart="0" file="spm-edk2-uart0_lts_v2.12.exp" track_expect

	payload_type="tftf" gen_yaml_template
}
