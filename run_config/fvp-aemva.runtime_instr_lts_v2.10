generate_lava_job() {
	local model="base-aemva"

	uart="0" timeout="60" file="pmf-tfa-boot_lts_v2.10.exp" track_expect
	uart="1" timeout="60" file="pmf-tfa-bl31-boot-exit_lts_v2.10.exp" track_expect
	model="$model" gen_model_params
	model="$model" gen_fvp_yaml
}
